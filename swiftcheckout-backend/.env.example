# ==========================================
# SwiftCheckout Backend - Environment Variables
# ==========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# Server Configuration
PORT=8080
BASE_URL=http://localhost:8080

# ==========================================
# Bitnob API Configuration (Sandbox)
# ==========================================
# Get these from your Bitnob dashboard: https://sandbox.bitnob.co
# Bitnob uses HMAC-SHA256 authentication (not Bearer tokens)
BITNOB_API_URL=https://sandboxapi.bitnob.co/api/v1
BITNOB_SECRET_KEY=your_hmac_secret_key_here
BITNOB_WEBHOOK_SECRET=your_webhook_secret_here
BITNOB_CUSTOMER_ID=your_client_id_here

# Webhook endpoint will be: http://localhost:8080/api/webhooks/bitnob
# Register this URL in your Bitnob dashboard

# ==========================================
# Kite Blockchain Configuration
# ==========================================
# Kite Testnet RPC
KITE_RPC_URL=https://rpc-testnet.gokite.ai

# Network name for x402 payments
KITE_NETWORK=kite-testnet

# Operator wallet private key (backend wallet that signs vault transactions)
# NEVER commit this to version control!
OPERATOR_PRIVATE_KEY=your_operator_private_key_here

# Deployed SwiftVault contract address
VAULT_ADDRESS=your_deployed_vault_address_here

# USDC.e token address on Kite testnet
USDC_ADDRESS=0x8E04D099b1a8Dd20E6caD4b2Ab2B405B98242ec9

# ==========================================
# Yield Management (Optional)
# ==========================================
# How often to deploy idle funds to yield (in milliseconds)
# Default: 1 hour (3600000ms)
YIELD_CHECK_INTERVAL_MS=3600000

# ==========================================
# Notes
# ==========================================
# 1. Get Bitnob credentials from: https://sandbox.bitnob.co
# 2. Deploy SwiftVault contract first to get VAULT_ADDRESS
# 3. Fund the operator wallet with some Kite testnet ETH for gas
# 4. Register merchants using: POST /api/merchant/register
# 5. Vault must have USDC liquidity before settlements work
